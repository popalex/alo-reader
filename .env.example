# Copy to .env and adjust. .env is gitignored and read by docker compose and,
# for local runs, by python-dotenv (api/app/config.py).

# Postgres container credentials.
POSTGRES_USER=alo
POSTGRES_PASSWORD=alo
POSTGRES_DB=alo

# Connection string used by the api and worker. The host `postgres` is the
# compose service name; change only this line to point at managed Postgres.
DATABASE_URL=postgresql+asyncpg://alo:alo@postgres:5432/alo

# Auth mode: "clerk" (public instance) or "none" (single-user self-host).
# REQUIRED — the API refuses to boot without an explicit value; there is no
# default. AUTH_MODE=none disables auth entirely: ONLY run it behind a private
# network, VPN/Tailscale, or reverse-proxy auth (DESIGN.md §0.1).
# The dev overlay (`make dev`) defaults to "none" for local hacking.
AUTH_MODE=none

# Clerk settings (AUTH_MODE=clerk only). CLERK_ISSUER is your Clerk frontend
# API origin (also the JWT `iss` claim); JWKS is fetched from
# <issuer>/.well-known/jwks.json. CLERK_AUDIENCE is checked only when set
# (Clerk session tokens carry `aud` only if your JWT template adds one).
#CLERK_ISSUER=https://your-app.clerk.accounts.dev
#CLERK_AUDIENCE=
#CLERK_PUBLISHABLE_KEY=pk_test_...
#CLERK_WEBHOOK_SECRET=whsec_...

# Per-user API rate limit (token bucket, per API replica).
#RATE_LIMIT_RPS=10
#RATE_LIMIT_BURST=30

# Minimum spacing (seconds) between manual per-feed refreshes, per API replica.
#SUBSCRIPTION_REFRESH_WINDOW_S=300

# Max personal access tokens a single user may hold (quota audit, DESIGN.md §1.4).
#QUOTA_API_TOKENS=20

# Minimum spacing (seconds) between /discover calls per user, per API replica.
# Discovery makes the server fetch an arbitrary page, so it's gated harder than
# the coarse global request bucket.
#DISCOVER_WINDOW_S=5

# Fetcher / poller (DESIGN.md §1.3). FETCH_CONTACT_URL is optional: if set, it's
# appended to the crawler User-Agent as "(+<url>)" so hosts can reach you — use a
# real, monitored address. Left unset, the UA is just "alo-reader/1.0". The caps
# bound per-fetch cost/abuse (total timeout, response size, redirect hops).
#FETCH_CONTACT_URL=https://your-site.example/contact
#FETCH_TIMEOUT_S=30
#FETCH_MAX_BYTES=5242880
#FETCH_MAX_REDIRECTS=5

# Comma-separated hostnames exempt from the SSRF private-range block (still must be
# http/https and resolvable). For trusted internal/test feed servers only — e.g. a
# fixture host on the compose network. Leave empty in production.
#FETCH_ALLOW_HOSTS=feedfixture

# Worker / poller (DESIGN.md §1.3). Claim loop cadence, batch size, lease, and
# the global concurrent-fetch cap.
#WORKER_POLL_INTERVAL_S=5
#WORKER_CLAIM_BATCH=50
#WORKER_LEASE_S=120
#WORKER_MAX_CONCURRENCY=20

# Per-origin-host politeness: max concurrent fetches to one host and the minimum
# spacing (seconds) between successive fetches to it.
#WORKER_PER_HOST_CONCURRENCY=1
#WORKER_PER_HOST_DELAY_S=1

# Fetch a feed's favicon on its first successful poll (best-effort, SSRF-guarded).
#WORKER_FETCH_FAVICONS=true

# Adaptive poll interval bounds (seconds): 15 min floor for active feeds, 24 h
# ceiling for dormant ones.
#WORKER_INTERVAL_FLOOR_S=900
#WORKER_INTERVAL_CEIL_S=86400

# Error backoff (seconds): base doubled per consecutive error, capped at 24 h.
#WORKER_BACKOFF_BASE_S=900
#WORKER_BACKOFF_CAP_S=86400
