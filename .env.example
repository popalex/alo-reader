# Copy to .env and adjust. .env is gitignored and read by docker compose and,
# for local runs, by python-dotenv (api/app/config.py).

# Postgres container credentials.
POSTGRES_USER=alo
POSTGRES_PASSWORD=alo
POSTGRES_DB=alo

# Connection string used by the api and worker. The host `postgres` is the
# compose service name; change only this line to point at managed Postgres.
DATABASE_URL=postgresql+asyncpg://alo:alo@postgres:5432/alo

# Auth mode: "clerk" (public instance) or "none" (single-user self-host).
# REQUIRED — the API refuses to boot without an explicit value; there is no
# default. AUTH_MODE=none disables auth entirely: ONLY run it behind a private
# network, VPN/Tailscale, or reverse-proxy auth (DESIGN.md §0.1).
# The dev overlay (`make dev`) defaults to "none" for local hacking.
AUTH_MODE=none

# Clerk settings (AUTH_MODE=clerk only). CLERK_ISSUER is your Clerk frontend
# API origin (also the JWT `iss` claim); JWKS is fetched from
# <issuer>/.well-known/jwks.json. CLERK_AUDIENCE is checked only when set
# (Clerk session tokens carry `aud` only if your JWT template adds one).
#CLERK_ISSUER=https://your-app.clerk.accounts.dev
#CLERK_AUDIENCE=
#CLERK_PUBLISHABLE_KEY=pk_test_...
#CLERK_WEBHOOK_SECRET=whsec_...

# Per-user API rate limit (token bucket, per API replica).
#RATE_LIMIT_RPS=10
#RATE_LIMIT_BURST=30
