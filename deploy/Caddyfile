# Production / `make up`: serve the built SPA and reverse-proxy the API.
# Listens on :80 (HTTP). Automatic TLS on a real domain is wired in WP-16.
:80 {
	encode gzip

	# /metrics is an internal-only ops surface (WP-15, DESIGN.md §1.4): reachable
	# from private networks (Prometheus on the same VPS/overlay), 403 from the
	# public internet. Must precede the general /api/* handler.
	@metrics path /api/v1/metrics
	handle @metrics {
		@external not remote_ip private_ranges
		respond @external "metrics are internal-only" 403
		reverse_proxy api:8000 {
			header_up X-Real-IP {http.request.client_ip}
		}
	}

	# Pass the real client IP to the API for its per-IP pre-auth rate limit. Caddy is
	# the edge, so {client_ip} is the direct peer and header_up overwrites any value a
	# client tried to send. If you later put a CDN/LB in front of Caddy, add a global
	# `servers { trusted_proxies static <cidrs> }` so {client_ip} resolves the true
	# client through X-Forwarded-For.
	@api path /api/*
	handle @api {
		reverse_proxy api:8000 {
			header_up X-Real-IP {http.request.client_ip}
		}
	}

	handle {
		# Security headers for the SPA (WP-15, DESIGN.md §1.6). The CSP is the second
		# XSS wall after ingest sanitization; it allows 'self' plus what Clerk and
		# rendered feed images legitimately need (scripts stay 'self' — the build uses
		# external/bundled scripts, not inline). HSTS matters once WP-16 wires TLS.
		header {
			Content-Security-Policy "default-src 'self'; script-src 'self' https://*.clerk.accounts.dev https://challenges.cloudflare.com; connect-src 'self' https://*.clerk.accounts.dev; img-src 'self' data: https:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; frame-src https://*.clerk.accounts.dev https://challenges.cloudflare.com; worker-src 'self' blob:; manifest-src 'self'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'"
			X-Content-Type-Options "nosniff"
			X-Frame-Options "DENY"
			Referrer-Policy "no-referrer"
			Cross-Origin-Opener-Policy "same-origin"
			Permissions-Policy "geolocation=(), camera=(), microphone=(), browsing-topics=()"
			Strict-Transport-Security "max-age=31536000; includeSubDomains"
			-Server
		}
		root * /srv
		try_files {path} /index.html
		file_server
	}
}
