{
  "title": "alo-reader · logs",
  "uid": "alo-logs",
  "editable": true,
  "schemaVersion": 39,
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "custom",
        "query": "alo-api,alo-worker",
        "includeAll": true,
        "allValue": ".+",
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "level",
        "type": "custom",
        "query": "error,warn,info,debug",
        "includeAll": true,
        "allValue": ".+",
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "logs",
      "title": "Application logs — each line prefixed with its service; filter by service + level; click a line for its trace_id",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 20, "w": 24, "x": 0, "y": 0 },
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "{service_name=~\"$service\"} | detected_level=~\"$level\" | line_format \"{{ printf \\\"%-7s\\\" (trimPrefix \\\"alo-\\\" .service_name) }}| {{ __line__ }}\"",
          "queryType": "range",
          "refId": "A"
        }
      ]
    }
  ]
}
