{
  "title": "alo-reader · logs",
  "uid": "alo-logs",
  "editable": true,
  "schemaVersion": 39,
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "custom",
        "query": ".*,alo-api,alo-worker",
        "current": { "text": ".*", "value": ".*" },
        "includeAll": false
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "logs",
      "title": "Application logs (filter by trace_id to correlate with a trace)",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 20, "w": 24, "x": 0, "y": 0 },
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "{service_name=~\"$service\"}",
          "queryType": "range",
          "refId": "A"
        }
      ]
    }
  ]
}
