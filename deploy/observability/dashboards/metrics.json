{
  "title": "alo-reader · metrics",
  "uid": "alo-metrics",
  "editable": true,
  "schemaVersion": 39,
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "custom",
        "query": ".*,alo-api,alo-worker",
        "current": { "text": ".*", "value": ".*" },
        "includeAll": false
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Feed fetch outcomes (rate by class)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum by (class) (rate(alo_fetch_outcomes_total{service_name=~\"$service\"}[$__rate_interval]))",
          "legendFormat": "{{class}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Feed fetch duration p50 / p95",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] },
      "targets": [
        {
          "editorMode": "code",
          "expr": "histogram_quantile(0.50, sum by (le) (rate(alo_fetch_duration_milliseconds_bucket[$__rate_interval])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "editorMode": "code",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(alo_fetch_duration_milliseconds_bucket[$__rate_interval])))",
          "legendFormat": "p95",
          "refId": "B"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Worker backlog lag",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        { "editorMode": "code", "expr": "max(alo_worker_lag_seconds)", "refId": "A" }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Entries inserted (rate)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum(rate(alo_entries_inserted_total[$__rate_interval]))",
          "legendFormat": "entries/s",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Table sizes (rows)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "editorMode": "code",
          "expr": "alo_table_rows",
          "legendFormat": "{{table}}",
          "refId": "A"
        }
      ]
    }
  ]
}
