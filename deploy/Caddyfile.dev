# Dev / `make dev`: proxy the API to the api service and everything else to the
# Vite dev server (so HMR works through a single http://localhost:3000 origin).
:3000 {
	@api path /api/*
	handle @api {
		# Dev-only: don't pool idle upstream connections. uvicorn --reload drops an
		# idle keepalive channel and emits a stray bare "HTTP/1.1 400 Bad Request",
		# which Caddy logs as "Unsolicited response received on idle HTTP channel".
		# Not reusing connections avoids the whole class of warning (prod keeps
		# keepalive — the prod Caddyfile/entrypoint handle the timeout properly).
		reverse_proxy api:8000 {
			transport http {
				keepalive off
			}
		}
	}

	# Browser OTLP export (only with the OTel overlay / make dev-otel). Strips /otlp so
	# /otlp/v1/traces reaches the collector as /v1/traces. Harmless without the overlay.
	handle_path /otlp/* {
		reverse_proxy otel-collector:4318
	}

	handle {
		reverse_proxy web:5173
	}
}
